# 配置文件模板
# 复制此文件为 .env 并填入你的实际配置
# .env 文件不会被提交到 Git（已在 .gitignore 中）

# ============================================
# Tushare API Token
# 从 https://tushare.pro/ 获取
# ============================================
TUSHARE_TOKEN=your_tushare_token_here

# ============================================
# 企业微信机器人 Webhook Key
# 从企业微信群里添加机器人获取
# ============================================
QYWX_WEBHOOK_KEY=your_qywx_webhook_key_here

# ============================================
# 可选：代理设置
# ============================================
# HTTP_PROXY=
# HTTPS_PROXY=
